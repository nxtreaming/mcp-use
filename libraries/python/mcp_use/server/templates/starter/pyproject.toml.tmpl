[project]
name = "{{PROJECT_NAME}}"
version = "0.1.0"
description = "An MCP server built with mcp-use"
requires-python = ">=3.11"
dependencies = [
    "mcp-use>=1.6.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=7.4.0",
    "ruff>=0.1.0",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["."]
only-include = ["server.py"]

[tool.ruff]
line-length = 120
target-version = "py311"
